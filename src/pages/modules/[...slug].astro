---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CheatSheet from '../../components/CheatSheet.astro';
import { getAllModules, getModuleBySlug, getExpandersFor } from '../../lib/modules';
import '../../styles/global.css';

export function getStaticPaths() {
  const modules = getAllModules();
  return modules.map(({ slug }) => ({
    params: { slug },
  }));
}

const { slug } = Astro.params;
const module = getModuleBySlug(slug!);

if (!module) {
  return Astro.redirect('/sheets/404');
}

const expanders = getExpandersFor(slug!);
---

<BaseLayout
  title={module.name}
  description={`${module.name} by ${module.manufacturer} — controls, I/O, behaviors, and patch ideas`}
  ogTitle={`${module.name} — ${module.manufacturer} · ${module.hp}HP`}
  ogDescription={module.description}
  ogImage={`/og/${slug}.png`}
>
  <CheatSheet module={module} expanders={expanders} />
</BaseLayout>
