---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getAllModules } from '../lib/modules';
import '../styles/global.css';

const allModules = getAllModules().sort((a, b) => a.module.name.localeCompare(b.module.name));
const basePath = import.meta.env.BASE_URL.replace(/\/$/, '');

// Top-level role chips. Each chip maps to a set of tags from modules.schema.json —
// a module matches the chip if any of its tags appear in `tags`. Order here is the
// order rendered on the page.
const ROLE_FILTERS: { id: string; label: string; tags: string[] }[] = [
  { id: 'oscillator', label: 'Oscillator', tags: ['OSCILLATOR', 'VCO'] },
  { id: 'filter', label: 'Filter', tags: ['VCF', 'FILTER'] },
  { id: 'env-lfo', label: 'Envelope / LFO', tags: ['ENVELOPE', 'LFO', 'FUNCTION', 'SLEW'] },
  { id: 'sequencer', label: 'Sequencer', tags: ['SEQUENCER', 'CLOCK', 'TRIGGER', 'LOGIC', 'SWITCH'] },
  { id: 'sampler', label: 'Sampler', tags: ['SAMPLER', 'GRANULAR'] },
  { id: 'fx', label: 'FX', tags: ['REVERB', 'DELAY', 'EFFECTS', 'DISTORTION', 'WAVESHAPER', 'PHASER', 'CHORUS', 'GLITCH', 'WAVEFOLDER', 'RESONATOR'] },
  { id: 'utility', label: 'Utility', tags: ['UTILITY', 'MIXER', 'VCA', 'ATTENUATOR', 'ATTENUVERTER', 'MULT', 'BUFFER', 'MIDI', 'I/O', 'EQ', 'COMPRESSOR', 'QUANTIZER', 'NOISE', 'RANDOM', 'GATE'] },
  { id: 'drum', label: 'Drum', tags: ['DRUM'] },
];

// Precompute each card's role-filter membership so the client-side filter is a
// simple attribute check — no repeated tag-matching at click time.
function rolesFor(tags: string[]): string[] {
  const set = new Set<string>();
  for (const filter of ROLE_FILTERS) {
    if (tags.some((t) => filter.tags.includes(t))) set.add(filter.id);
  }
  return Array.from(set);
}

// Group by manufacturer while preserving an alphabetized module order within each group.
const grouped = new Map<string, typeof allModules>();
for (const entry of allModules) {
  const bucket = grouped.get(entry.module.manufacturer) ?? [];
  bucket.push(entry);
  grouped.set(entry.module.manufacturer, bucket);
}
const manufacturersSorted = Array.from(grouped.keys()).sort((a, b) => a.localeCompare(b));

const SUGGESTION_CHIPS = [
  'self-patching',
  'quantizer',
  '< 8HP',
  'stereo in',
  'triggers on rise',
  'generative',
];

function roleLine(tags: string[]): string {
  // Spec: "role = first entry of tags[], lowercased".
  return (tags[0] ?? '').toLowerCase();
}

// Count per role-filter for the chip labels.
const roleCounts: Record<string, number> = { all: allModules.length };
for (const filter of ROLE_FILTERS) {
  roleCounts[filter.id] = allModules.filter((e) =>
    rolesFor(e.module.tags).includes(filter.id),
  ).length;
}
---

<BaseLayout title="Home">
  <div class="flex flex-col items-center min-h-screen px-4 md:px-7 py-10 md:py-16">
    <h1 class="text-[13px] md:text-[15px] font-semibold tracking-[4px] md:tracking-[6px] uppercase text-fg mb-2 flex items-center gap-2.5 md:gap-3">
      <svg class="w-5 h-5 md:w-6 md:h-6 shrink-0" viewBox="0 0 48 48" aria-hidden="true">
        <rect x="5" y="5" width="38" height="38" rx="2" fill="#1a1a1a"/>
        <g fill="none" stroke="#f7f5f0" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="10" cy="10" r="1.8" stroke-width="1.2"/>
          <circle cx="38" cy="10" r="1.8" stroke-width="1.2"/>
          <circle cx="10" cy="38" r="1.8" stroke-width="1.2"/>
          <circle cx="38" cy="38" r="1.8" stroke-width="1.2"/>
          <line x1="15" y1="24" x2="33" y2="24" stroke-width="0.6" opacity="0.3"/>
          <line x1="24" y1="15" x2="24" y2="33" stroke-width="0.6" opacity="0.3"/>
          <path d="M 13 24 C 16 24, 17 32, 20 32 C 23 32, 23 16, 26 16 C 29 16, 30 24, 35 24" stroke-width="2"/>
        </g>
        <circle cx="26" cy="16" r="2" fill="#d9571f"/>
      </svg>
      <span>Voltpages</span>
    </h1>
    <p class="text-subtle text-xs mb-6 md:mb-8">Quick-reference cheat sheets for eurorack modules</p>

    <!-- Search input -->
    <div class="w-full max-w-[480px]">
      <input
        id="search-input"
        type="text"
        placeholder="Search modules, patches, behaviors..."
        autocomplete="off"
        aria-label="Search modules, patches, behaviors"
        class="w-full text-base border-2 border-border-strong bg-white text-fg py-3.5 px-5 outline-none"
      />
    </div>

    <!-- Suggestion chips -->
    <div class="mt-3 flex flex-wrap gap-1.5 justify-center max-w-[480px]">
      {SUGGESTION_CHIPS.map((label) => (
        <button type="button" class="suggestion-chip chip chip--touch" data-suggest={label}>{label}</button>
      ))}
    </div>

    <p class="mt-4 md:mt-6 text-[11px] text-subtle tracking-wide flex items-center gap-2 flex-wrap justify-center">
      <span id="module-count">{allModules.length} modules</span>
      <span aria-hidden="true">·</span>
      <a href="https://github.com/ogabrielluiz/voltpages" class="underline underline-offset-2 text-faint hover:text-fg">GitHub</a>
      <span aria-hidden="true">·</span>
      <a href="https://github.com/ogabrielluiz/voltpages/blob/main/CONTRIBUTING.md" class="underline underline-offset-2 text-faint hover:text-fg">contribute</a>
      <span aria-hidden="true">·</span>
      <a href="https://www.buymeacoffee.com/ogabrielluiz" target="_blank" rel="noopener noreferrer" class="underline underline-offset-2 text-faint hover:text-fg">☕ support</a>
    </p>

    <!-- Role filter rail -->
    <div class="mt-6 md:mt-8 w-full max-w-[1100px] overflow-x-auto">
      <div id="role-filters" class="flex gap-1.5 flex-nowrap md:flex-wrap justify-start md:justify-center" role="tablist" aria-label="Filter by role">
        <button type="button" class="role-chip chip chip--touch is-active" data-role="all" aria-pressed="true">
          All · {roleCounts.all}
        </button>
        {ROLE_FILTERS.filter((f) => roleCounts[f.id] > 0).map((filter) => (
          <button type="button" class="role-chip chip chip--touch" data-role={filter.id} aria-pressed="false">
            {filter.label} · {roleCounts[filter.id]}
          </button>
        ))}
      </div>
    </div>

    <!-- Active raw-tag filter pill (shown when ?tag= is in the URL, e.g. from
         clicking a tag chip in a module header). Rendered hidden; JS reveals
         it if a tag filter is active. -->
    <div id="tag-filter-pill" class="mt-4 hidden w-full max-w-[1100px] flex justify-center">
      <button type="button" class="chip chip--touch chip--accent" id="tag-filter-clear" aria-label="Clear tag filter">
        <span class="kicker" style="font-size: 10px; letter-spacing: 2px; margin-right: 4px">Tag</span>
        <span id="tag-filter-label"></span>
        <span aria-hidden="true" class="ml-1">✕</span>
      </button>
    </div>

    <!-- Module grid -->
    <div class="mt-6 md:mt-8 w-full max-w-[1100px]">
      <!-- Grouped view (default) -->
      <div id="grouped-grid" aria-live="polite" aria-atomic="false">
        {manufacturersSorted.map((manufacturer) => {
          const entries = grouped.get(manufacturer)!;
          const mfrSlug = manufacturer.toLowerCase().replace(/[^a-z0-9]+/g, '-');
          return (
            <section class="mfr-group mb-6" data-manufacturer={mfrSlug}>
              <h2 class="mfr-header micro sticky top-0 bg-bg z-[1] pb-1 mb-2 border-b border-border">{manufacturer}</h2>
              <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 border-t border-l border-border">
                {entries.map(({ slug, module }) => {
                  const roles = rolesFor(module.tags);
                  return (
                    <a href={`${basePath}/modules/${slug}/`}
                       data-slug={slug}
                       data-name={module.name.toLowerCase()}
                       data-manufacturer={module.manufacturer.toLowerCase()}
                       data-tags={module.tags.join(' ').toLowerCase()}
                       data-roles={roles.join(' ')}
                       data-hp={module.hp}
                       class="module-card px-3 py-3 border-r border-b border-border hover:bg-surface no-underline flex flex-col">
                      <div class="flex items-baseline justify-between gap-2">
                        <span class="block text-sm font-semibold text-fg truncate">{module.name}</span>
                        <span class="hidden sm:inline text-[10px] font-mono text-faint shrink-0">{module.hp}HP</span>
                      </div>
                      <span class="block text-[11px] text-subtle mt-0.5">
                        {module.manufacturer}
                        {module.tags.length > 0 && (
                          <span class="text-faint"> · {roleLine(module.tags)}</span>
                        )}
                      </span>
                      <span class="match-count hidden text-[10px] font-mono uppercase tracking-[1.5px] text-accent mt-1"></span>
                    </a>
                  );
                })}
              </div>
            </section>
          );
        })}
      </div>

      <!-- Empty state (shown when filters/query return zero results) -->
      <div id="empty-state" class="hidden py-16 text-center" role="status" aria-live="polite">
        <p class="text-fg text-base mb-1">No matches <span id="empty-state-query" class="font-mono text-subtle"></span></p>
        <p class="text-subtle text-[13px] mb-5">Nothing in this corner of the rack yet.</p>
        <div class="flex gap-2 justify-center flex-wrap">
          <button type="button" id="empty-state-clear" class="chip chip--touch">Clear search</button>
          <button type="button" id="empty-state-browse" class="chip chip--touch is-active">Browse all {allModules.length}</button>
        </div>
      </div>

      <!-- Flat grid (hidden by default — shown when a tag filter or search is active) -->
      <div id="flat-grid" class="hidden grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 border-t border-l border-border" aria-live="polite" aria-atomic="false">
        {allModules.map(({ slug, module }) => {
          const roles = rolesFor(module.tags);
          return (
            <a href={`${basePath}/modules/${slug}/`}
               data-slug={slug}
               data-name={module.name.toLowerCase()}
               data-manufacturer={module.manufacturer.toLowerCase()}
               data-tags={module.tags.join(' ').toLowerCase()}
               data-roles={roles.join(' ')}
               data-hp={module.hp}
               class="module-card flat-card px-3 py-3 border-r border-b border-border hover:bg-surface no-underline flex flex-col">
              <div class="flex items-baseline justify-between gap-2">
                <span class="block text-sm font-semibold text-fg truncate">{module.name}</span>
                <span class="hidden sm:inline text-[10px] font-mono text-faint shrink-0">{module.hp}HP</span>
              </div>
              <span class="block text-[11px] text-subtle mt-0.5">
                {module.manufacturer}
                {module.tags.length > 0 && (
                  <span class="text-faint"> · {roleLine(module.tags)}</span>
                )}
              </span>
              <span class="match-count hidden text-[10px] font-mono uppercase tracking-[1.5px] text-accent mt-1"></span>
            </a>
          );
        })}
      </div>
    </div>

  </div>

  <!-- Pagefind search API (not the UI widget) -->
  <script is:inline define:vars={{ basePath }}>
    let pagefind = null;
    let searchTimeout = null;

    async function initPagefind() {
      if (pagefind) return pagefind;
      try {
        pagefind = await import(basePath + '/pagefind/pagefind.js');
        await pagefind.init();
      } catch (e) {
        pagefind = null;
      }
      return pagefind;
    }

    // F-02 typed badges. Each module page tags its section headings with
    // stable ids (h-patches / h-behaviors / h-controls / h-io). Pagefind's
    // sub_results group matches by nearest preceding heading id, so we can
    // attribute "where in the sheet did this query hit" by looking at the
    // anchor fragment on each sub_result URL.
    const ANCHOR_TO_TYPE = {
      'h-patches': 'patches',
      'h-behaviors': 'behaviors',
      'h-controls': 'controls',
      'h-io': 'io',
    };
    const TYPE_LABEL = {
      patches: { singular: 'patch', plural: 'patches' },
      behaviors: { singular: 'behavior', plural: 'behaviors' },
      controls: { singular: 'control', plural: 'controls' },
      io: { singular: 'I/O', plural: 'I/O' },
    };

    function getActiveRole() {
      const url = new URL(window.location.href);
      return url.searchParams.get('role') || 'all';
    }

    function setActiveRoleInURL(role) {
      const url = new URL(window.location.href);
      if (role && role !== 'all') url.searchParams.set('role', role);
      else url.searchParams.delete('role');
      window.history.replaceState({}, '', url.toString());
    }

    // Raw-tag filter (N-06). Populated by external links (module-header tag
    // chips) and dismissed via the tag-filter pill.
    function getActiveTag() {
      const url = new URL(window.location.href);
      const raw = url.searchParams.get('tag');
      return raw ? raw.trim() : null;
    }

    function setActiveTagInURL(tag) {
      const url = new URL(window.location.href);
      if (tag) url.searchParams.set('tag', tag);
      else url.searchParams.delete('tag');
      window.history.replaceState({}, '', url.toString());
    }

    function renderTagPill(tag) {
      const pill = document.getElementById('tag-filter-pill');
      const label = document.getElementById('tag-filter-label');
      if (!pill || !label) return;
      if (tag) {
        label.textContent = tag;
        pill.classList.remove('hidden');
      } else {
        pill.classList.add('hidden');
        label.textContent = '';
      }
    }

    function switchView(isFlat) {
      const grouped = document.getElementById('grouped-grid');
      const flat = document.getElementById('flat-grid');
      if (!grouped || !flat) return;
      if (isFlat) {
        grouped.classList.add('hidden');
        flat.classList.remove('hidden');
      } else {
        flat.classList.add('hidden');
        grouped.classList.remove('hidden');
      }
    }

    function applyFiltersAndCount(query, role, slugCounts, tag) {
      const isFlat = (role && role !== 'all') || (query && query.length >= 2) || Boolean(tag);
      switchView(isFlat);

      const cards = document.querySelectorAll(isFlat ? '#flat-grid .module-card' : '#grouped-grid .module-card');
      const q = (query || '').toLowerCase();
      const tagLower = tag ? tag.toLowerCase() : null;
      let visible = 0;

      cards.forEach((card) => {
        const slug = card.dataset.slug;
        const name = card.dataset.name || '';
        const mfr = card.dataset.manufacturer || '';
        const tagsAttr = card.dataset.tags || '';
        const roles = (card.dataset.roles || '').split(' ');

        const roleMatch = !role || role === 'all' || roles.includes(role);
        // data-tags stores tags space-separated; match on word boundaries so
        // "vco" doesn't incidentally match "vcovcf". Every tag already tokenises
        // cleanly in the schema (uppercase, hyphens, slashes are the only
        // non-letters), so a split + includes is exact.
        const tagMatch = !tagLower || tagsAttr.split(' ').includes(tagLower);
        let queryMatch = true;
        if (q.length >= 2) {
          const pagefindHit = slugCounts && slugCounts[slug];
          const localHit = name.includes(q) || mfr.includes(q) || tagsAttr.includes(q);
          queryMatch = Boolean(pagefindHit) || localHit;
        }
        const isMatch = roleMatch && tagMatch && queryMatch;
        card.style.display = isMatch ? '' : 'none';

        const badge = card.querySelector('.match-count');
        if (badge) {
          const hits = slugCounts && slugCounts[slug];
          const label = q.length >= 2 ? formatTypedBadge(hits) : null;
          if (label) {
            badge.textContent = label;
            badge.classList.remove('hidden');
          } else {
            badge.classList.add('hidden');
            badge.textContent = '';
          }
        }

        if (isMatch) visible++;
      });

      // Hide manufacturer groups that have no visible cards
      if (!isFlat) {
        document.querySelectorAll('.mfr-group').forEach((group) => {
          const hasVisible = Array.from(group.querySelectorAll('.module-card'))
            .some((c) => c.style.display !== 'none');
          group.style.display = hasVisible ? '' : 'none';
        });
      }

      // Empty-state (N-07): when filters narrow the view to zero, swap the
      // grid for a recoverable block. The status container is aria-live so
      // the empty-ness gets announced.
      const hasAnyFilter = isFlat; // any filter or a query forces flat view
      const emptyEl = document.getElementById('empty-state');
      const groupedEl = document.getElementById('grouped-grid');
      const flatEl = document.getElementById('flat-grid');
      if (emptyEl) {
        if (hasAnyFilter && visible === 0) {
          emptyEl.classList.remove('hidden');
          if (groupedEl) groupedEl.classList.add('hidden');
          if (flatEl) flatEl.classList.add('hidden');
          const queryEl = document.getElementById('empty-state-query');
          if (queryEl) queryEl.textContent = q ? `for "${query}"` : '';
        } else {
          emptyEl.classList.add('hidden');
        }
      }

      const countEl = document.getElementById('module-count');
      if (countEl) countEl.textContent = `${visible} modules`;
    }

    async function runPagefindSearch(query) {
      const pf = await initPagefind();
      if (!pf) return null;
      try {
        const search = await pf.search(query);
        const results = await Promise.all(search.results.map((r) => r.data()));
        const slugHits = {};
        for (const result of results) {
          const m = result.url.match(/\/modules\/([^/]+)/);
          if (!m) continue;
          const slug = m[1];
          if (!slugHits[slug]) slugHits[slug] = { total: 0, patches: 0, behaviors: 0, controls: 0, io: 0 };
          slugHits[slug].total += 1;

          // Each result has sub_results — one per heading-id section the query
          // matched inside. Sub_results without an anchor are the page-level
          // match (typically the module name); we count those into total but
          // don't attribute them to a section type.
          const subs = result.sub_results || [];
          for (const sr of subs) {
            const anchorId = sr.anchor?.id;
            const type = anchorId && ANCHOR_TO_TYPE[anchorId];
            if (type) slugHits[slug][type] += 1;
          }
        }
        // Work out the dominant section type per slug for the badge.
        for (const slug of Object.keys(slugHits)) {
          const hits = slugHits[slug];
          const typed = Object.keys(ANCHOR_TO_TYPE)
            .map((id) => ANCHOR_TO_TYPE[id])
            .map((type) => ({ type, count: hits[type] || 0 }))
            .filter((x) => x.count > 0)
            .sort((a, b) => b.count - a.count);
          hits.dominant = typed[0] || null;
        }
        return slugHits;
      } catch (e) {
        return null;
      }
    }

    function formatTypedBadge(hits) {
      if (!hits) return null;
      if (hits.dominant) {
        const { type, count } = hits.dominant;
        const label = TYPE_LABEL[type];
        if (!label) return null;
        const word = count === 1 ? label.singular : label.plural;
        return `${count} ${word}`;
      }
      // No section-tagged hit — the match was page-level (name / manufacturer).
      // Show an untyped count so the badge still tells the user "this card has
      // content matching your query" rather than going silent.
      if (hits.total > 0) return hits.total === 1 ? '1 match' : `${hits.total} matches`;
      return null;
    }

    async function handleSearch(query, role, tag) {
      role = role || getActiveRole();
      tag = tag === undefined ? getActiveTag() : tag;
      renderTagPill(tag);
      if (!query || query.length < 2) {
        applyFiltersAndCount('', role, null, tag);
        return;
      }
      const slugCounts = await runPagefindSearch(query);
      applyFiltersAndCount(query, role, slugCounts || {}, tag);
    }

    document.addEventListener('DOMContentLoaded', () => {
      const input = document.getElementById('search-input');
      const roleButtons = document.querySelectorAll('.role-chip');
      const suggestionChips = document.querySelectorAll('.suggestion-chip');
      if (!input) return;

      // Restore role filter from URL
      const initialRole = getActiveRole();
      roleButtons.forEach((btn) => {
        const active = btn.dataset.role === initialRole;
        btn.classList.toggle('is-active', active);
        btn.setAttribute('aria-pressed', active ? 'true' : 'false');
      });

      input.addEventListener('input', () => {
        clearTimeout(searchTimeout);
        searchTimeout = setTimeout(() => handleSearch(input.value.trim()), 120);
      });

      roleButtons.forEach((btn) => {
        btn.addEventListener('click', () => {
          const role = btn.dataset.role;
          roleButtons.forEach((b) => {
            const active = b === btn;
            b.classList.toggle('is-active', active);
            b.setAttribute('aria-pressed', active ? 'true' : 'false');
          });
          setActiveRoleInURL(role);
          // Role and raw-tag are different browse axes; picking a role clears
          // the raw-tag so users aren't surprised by a double-narrowed view.
          setActiveTagInURL(null);
          handleSearch(input.value.trim(), role, null);
        });
      });

      // Tag filter pill — clicking anywhere on it clears the tag.
      const tagClear = document.getElementById('tag-filter-clear');
      if (tagClear) {
        tagClear.addEventListener('click', () => {
          setActiveTagInURL(null);
          handleSearch(input.value.trim(), getActiveRole(), null);
        });
      }

      // Empty-state recovery buttons (N-07).
      const emptyClear = document.getElementById('empty-state-clear');
      if (emptyClear) {
        emptyClear.addEventListener('click', () => {
          input.value = '';
          handleSearch('', getActiveRole(), getActiveTag());
        });
      }
      const emptyBrowse = document.getElementById('empty-state-browse');
      if (emptyBrowse) {
        emptyBrowse.addEventListener('click', () => {
          input.value = '';
          setActiveRoleInURL('all');
          setActiveTagInURL(null);
          roleButtons.forEach((b) => {
            const active = b.dataset.role === 'all';
            b.classList.toggle('is-active', active);
            b.setAttribute('aria-pressed', active ? 'true' : 'false');
          });
          handleSearch('', 'all', null);
        });
      }

      suggestionChips.forEach((chip) => {
        chip.addEventListener('click', () => {
          input.value = chip.dataset.suggest || '';
          input.dispatchEvent(new Event('input', { bubbles: true }));
          input.focus();
        });
      });

      // Keyboard: "/" focuses the search input (unless already typing in one)
      document.addEventListener('keydown', (e) => {
        if (e.key === '/' && !e.metaKey && !e.ctrlKey && !e.altKey) {
          const tag = document.activeElement?.tagName;
          if (tag === 'INPUT' || tag === 'TEXTAREA') return;
          e.preventDefault();
          input.focus();
        }
      });

      // Initial apply so role=... / tag=... URL params filter the view on first load.
      handleSearch(input.value.trim(), initialRole, getActiveTag());
      input.focus();
    });
  </script>
</BaseLayout>
