---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getAllModules } from '../lib/modules';
import '../styles/global.css';

const allModules = getAllModules().sort((a, b) => a.module.name.localeCompare(b.module.name));
const basePath = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<BaseLayout title="Home">
  <div class="flex flex-col items-center min-h-screen px-4 md:px-7 py-10 md:py-16">
    <h1 class="text-[13px] md:text-[15px] font-semibold tracking-[4px] md:tracking-[6px] uppercase text-fg mb-2">
      Voltpages
    </h1>
    <p class="text-subtle text-xs mb-6 md:mb-8">Quick-reference cheat sheets for eurorack modules</p>

    <!-- Search input -->
    <div class="w-full max-w-[480px]">
      <input
        id="search-input"
        type="text"
        placeholder="Search modules, patches, behaviors..."
        class="w-full font-mono text-base border-2 border-border-strong bg-white text-fg py-3.5 px-5 outline-none"
      />
    </div>

    <p class="mt-4 md:mt-6 text-[11px] text-subtle tracking-wide">
      <span id="module-count">{allModules.length} modules</span> ·
      <a href="https://github.com/ogabrielluiz/voltpages" class="underline underline-offset-2 text-faint hover:text-fg">contribute</a>
    </p>

    <!-- Module grid — filtered by Pagefind -->
    <div class="mt-8 md:mt-10 w-full max-w-[900px]">
      <div id="module-grid" class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 border-t border-l border-border">
        {allModules.map(({ slug, module }) => (
          <a href={`${basePath}/modules/${slug}/`}
             data-slug={slug}
             data-name={module.name.toLowerCase()}
             data-manufacturer={module.manufacturer.toLowerCase()}
             data-tags={module.tags.join(' ').toLowerCase()}
             class="module-card px-3 py-3 border-r border-b border-border hover:bg-surface no-underline">
            <span class="block text-sm font-semibold text-fg">{module.name}</span>
            <span class="block text-[11px] text-subtle mt-0.5">{module.manufacturer}</span>
            <span class="match-count hidden text-[10px] font-mono text-highlight mt-1"></span>
          </a>
        ))}
      </div>
    </div>

    <div class="flex-1"></div>

    <footer class="mt-8 mb-4 flex flex-col items-center gap-3">
      <a href="https://www.buymeacoffee.com/ogabrielluiz" target="_blank" rel="noopener noreferrer">
        <img src="https://cdn.buymeacoffee.com/buttons/v2/default-yellow.png" alt="Buy Me A Coffee" class="h-[40px] w-[145px]" />
      </a>
    </footer>
  </div>

  <!-- Pagefind search API (not the UI widget) -->
  <script is:inline define:vars={{ basePath }}>
    let pagefind = null;
    let searchTimeout = null;

    async function initPagefind() {
      if (pagefind) return pagefind;
      try {
        pagefind = await import(basePath + '/pagefind/pagefind.js');
        await pagefind.init();
      } catch (e) {
        // Pagefind not available (dev mode) — fall back to local filtering
        pagefind = null;
      }
      return pagefind;
    }

    function localFilter(query) {
      // Fallback: filter cards by name/manufacturer/tags when Pagefind isn't available
      const cards = document.querySelectorAll('.module-card');
      const q = query.toLowerCase();
      let visible = 0;
      cards.forEach(card => {
        const name = card.dataset.name || '';
        const mfr = card.dataset.manufacturer || '';
        const tags = card.dataset.tags || '';
        const match = name.includes(q) || mfr.includes(q) || tags.includes(q);
        card.style.display = match ? '' : 'none';
        const badge = card.querySelector('.match-count');
        if (badge) { badge.classList.add('hidden'); badge.textContent = ''; }
        if (match) visible++;
      });
      document.getElementById('module-count').textContent = `${visible} modules`;
    }

    function resetGrid() {
      const cards = document.querySelectorAll('.module-card');
      cards.forEach(card => {
        card.style.display = '';
        const badge = card.querySelector('.match-count');
        if (badge) { badge.classList.add('hidden'); badge.textContent = ''; }
      });
      document.getElementById('module-count').textContent = `${cards.length} modules`;
    }

    async function handleSearch(query) {
      if (!query || query.length < 2) {
        resetGrid();
        return;
      }

      const pf = await initPagefind();
      if (!pf) {
        localFilter(query);
        return;
      }

      const search = await pf.search(query);
      const results = await Promise.all(search.results.map(r => r.data()));

      // Count mentions per module slug
      const slugCounts = {};
      for (const result of results) {
        // URL looks like /voltpages/modules/make-noise--maths/
        const match = result.url.match(/\/modules\/([^/]+)/);
        if (match) {
          const slug = match[1];
          slugCounts[slug] = (slugCounts[slug] || 0) + 1;
        }
      }

      // Also do a local name/manufacturer match so typing "intellijel" always shows their modules
      const cards = document.querySelectorAll('.module-card');
      const q = query.toLowerCase();
      let visible = 0;

      cards.forEach(card => {
        const slug = card.dataset.slug;
        const name = card.dataset.name || '';
        const mfr = card.dataset.manufacturer || '';
        const tags = card.dataset.tags || '';
        const pagefindMatch = slugCounts[slug];
        const localMatch = name.includes(q) || mfr.includes(q) || tags.includes(q);
        const isMatch = pagefindMatch || localMatch;

        card.style.display = isMatch ? '' : 'none';

        const badge = card.querySelector('.match-count');
        if (badge) {
          if (pagefindMatch && pagefindMatch > 0) {
            const word = pagefindMatch === 1 ? 'mention' : 'mentions';
            badge.textContent = `${pagefindMatch} ${word}`;
            badge.classList.remove('hidden');
          } else {
            badge.classList.add('hidden');
            badge.textContent = '';
          }
        }

        if (isMatch) visible++;
      });

      document.getElementById('module-count').textContent = `${visible} modules`;
    }

    document.addEventListener('DOMContentLoaded', () => {
      const input = document.getElementById('search-input');
      if (!input) return;

      input.addEventListener('input', () => {
        clearTimeout(searchTimeout);
        searchTimeout = setTimeout(() => handleSearch(input.value.trim()), 200);
      });

      // Focus on load
      input.focus();
    });
  </script>
</BaseLayout>
