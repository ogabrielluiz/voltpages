---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getAllModules } from '../lib/modules';
import '../styles/global.css';

const allModules = getAllModules().sort((a, b) => a.module.name.localeCompare(b.module.name));
const basePath = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<BaseLayout title="Home">
  <div class="flex flex-col items-center min-h-screen px-4 md:px-7 py-10 md:py-16">
    <h1 class="text-[13px] md:text-[15px] font-semibold tracking-[4px] md:tracking-[6px] uppercase text-fg mb-2">
      Eurorack Sheets
    </h1>
    <p class="text-subtle text-xs mb-6 md:mb-8">Quick-reference cheat sheets for eurorack modules</p>

    <!-- Pagefind search widget -->
    <div id="search" class="w-full max-w-[480px]"></div>

    <p class="mt-4 md:mt-6 text-[11px] text-subtle tracking-wide">
      {allModules.length} modules ·
      <a href="https://github.com/ogabrielluiz/sheets" class="underline underline-offset-2 text-faint hover:text-fg">contribute</a>
    </p>

    <!-- All modules, sorted alphabetically -->
    <div class="mt-8 md:mt-10 w-full max-w-[720px]">
      <div class="flex flex-wrap gap-1.5">
        {allModules.map(({ slug, module }) => (
          <a href={`${basePath}/modules/${slug}/`}
             class="px-2.5 md:px-3 py-1.5 bg-surface text-[12px] md:text-[13px] font-semibold text-fg border border-border hover:border-border-strong no-underline">
            {module.name}
          </a>
        ))}
      </div>
    </div>
  </div>

  <!-- Pagefind initialization -->
  <link href={`${basePath}/pagefind/pagefind-ui.css`} rel="stylesheet" />
  <script is:inline define:vars={{ basePath }}>
    window.addEventListener('DOMContentLoaded', () => {
      if (typeof PagefindUI !== 'undefined') {
        new PagefindUI({
          element: "#search",
          showSubResults: false,
          showImages: false,
          baseUrl: basePath,
          pageSize: 8,
          translations: {
            placeholder: "Search modules...",
            zero_results: "No modules found for [SEARCH_TERM]"
          }
        });
      }
    });
  </script>
  <script src={`${basePath}/pagefind/pagefind-ui.js`} is:inline></script>

  <!-- Override Pagefind UI styles to match Rams aesthetic -->
  <style is:global>
    .pagefind-ui__search-input {
      font-family: "SF Mono", "Courier New", monospace !important;
      font-size: 16px !important;
      border: 2px solid #1a1a1a !important;
      border-radius: 0 !important;
      background: #fff !important;
      color: #1a1a1a !important;
      padding: 14px 18px 14px 44px !important;
    }
    .pagefind-ui__search-clear {
      color: #888 !important;
    }
    .pagefind-ui__result-link {
      font-weight: 600 !important;
      color: #1a1a1a !important;
    }
    .pagefind-ui__result-excerpt {
      color: #555 !important;
    }
    .pagefind-ui__button {
      background: #1a1a1a !important;
      color: #f7f5f0 !important;
      border-radius: 0 !important;
    }
  </style>
</BaseLayout>
