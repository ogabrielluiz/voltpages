---
import type { PatchIdea } from '../types/module';
import { render as renderPatchflow } from '@ogabrielluiz/patchflow';

interface Props {
  patchIdeas: PatchIdea[];
}

const { patchIdeas } = Astro.props;

// Pre-render diagrams at build time
const renderedDiagrams: Map<string, string> = new Map();
for (const idea of patchIdeas) {
  if (idea.diagram) {
    try {
      const svg = renderPatchflow(idea.diagram);
      renderedDiagrams.set(idea.name, svg);
    } catch (err) {
      console.warn(`[PatchIdeas] Failed to render diagram for "${idea.name}":`, (err as Error).message);
    }
  }
}

// Assign a sequential index across all diagrams on the page
let globalIndex = 0;
const ideaIndexes: Map<string, number> = new Map();
for (const idea of patchIdeas) {
  if (renderedDiagrams.has(idea.name)) {
    ideaIndexes.set(idea.name, globalIndex++);
  }
}
---

<div class="mt-7">
  <h2 class="text-xs uppercase tracking-[3px] text-subtle font-mono mb-3">Patch Ideas</h2>
  <div class="flex flex-col gap-2.5">
    {patchIdeas.map((idea) => {
      const diagramSvg = renderedDiagrams.get(idea.name);
      const diagramIndex = ideaIndexes.get(idea.name);
      return (
        <div class="pl-3 border-l-2 border-border-strong">
          <div class="text-[15px] font-semibold text-fg">{idea.name}</div>
          <div class="text-[13px] text-muted leading-relaxed mt-0.5">{idea.patch}</div>

          {idea.steps && idea.steps.length > 0 && (
            <div class="mt-2.5 text-[13px] leading-relaxed">
              <div class="text-[10px] font-mono text-subtle uppercase tracking-[2px] mb-1">Walkthrough</div>
              <ol class="list-decimal ml-5 text-muted space-y-0.5 marker:text-subtle marker:font-mono marker:text-[11px]">
                {idea.steps.map((step) => (
                  <li>{step}</li>
                ))}
              </ol>
              {idea.signalOut && (
                <div class="mt-2 text-muted">
                  <span class="text-[10px] font-mono text-subtle uppercase tracking-[2px] mr-2">Signal out</span>
                  {idea.signalOut}
                </div>
              )}
              {idea.hear && (
                <div class="mt-1 text-muted">
                  <span class="text-[10px] font-mono text-subtle uppercase tracking-[2px] mr-2">Listen for</span>
                  {idea.hear}
                </div>
              )}
            </div>
          )}

          {diagramSvg && (
            <details class="mt-2 group">
              <summary class="text-[11px] font-mono text-subtle cursor-pointer tracking-wide uppercase hover:text-fg select-none list-none inline-flex items-center gap-1 py-1">
                <span class="inline-block transition-transform group-open:rotate-90">▸</span>
                <span class="group-open:hidden">Show diagram</span>
                <span class="hidden group-open:inline">Hide diagram</span>
              </summary>
              <div class="diagram-shell mt-2">
                <button
                  type="button"
                  class="diagram-expand-btn"
                  aria-label="Open diagram in larger view"
                  data-diagram-index={diagramIndex}
                >⤢</button>
                <div class="diagram-container p-3 bg-white border border-border overflow-x-auto">
                  <div class="diagram-svg" set:html={diagramSvg} />
                  <div class="diagram-mark" aria-hidden="true">
                    <svg viewBox="0 0 48 48" width="14" height="14">
                      <rect x="5" y="5" width="38" height="38" rx="2" fill="#1a1a1a"/>
                      <g fill="none" stroke="#f7f5f0" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="10" cy="10" r="1.8" stroke-width="1.2"/>
                        <circle cx="38" cy="10" r="1.8" stroke-width="1.2"/>
                        <circle cx="10" cy="38" r="1.8" stroke-width="1.2"/>
                        <circle cx="38" cy="38" r="1.8" stroke-width="1.2"/>
                        <path d="M 13 24 C 16 24, 17 32, 20 32 C 23 32, 23 16, 26 16 C 29 16, 30 24, 35 24" stroke-width="2"/>
                      </g>
                      <circle cx="26" cy="16" r="2" fill="#d9571f"/>
                    </svg>
                    <span>Voltpages</span>
                  </div>
                </div>
              </div>
            </details>
          )}
        </div>
      );
    })}
  </div>
</div>

<dialog id="diagram-lightbox" class="diagram-lightbox">
  <form method="dialog" class="diagram-lightbox-close-form">
    <button type="submit" class="diagram-lightbox-close" aria-label="Close">✕</button>
  </form>
  <div id="diagram-lightbox-body" class="diagram-lightbox-body"></div>
</dialog>

<script is:inline>
  (function () {
    const dialog = document.getElementById('diagram-lightbox');
    const body = document.getElementById('diagram-lightbox-body');
    if (!dialog || !body) return;

    function applyDiagramSizing(root) {
      root.querySelectorAll('.diagram-svg > svg').forEach((svg) => {
        const minWidth = Number(svg.getAttribute('data-pf-min-width') || 0);
        if (!minWidth) return;
        svg.style.width = `${minWidth}px`;
        svg.style.minWidth = `${minWidth}px`;
        svg.style.maxWidth = 'none';
        svg.style.height = 'auto';
        svg.style.display = 'block';
      });
    }

    const MARK_HTML = `
      <div class="diagram-mark diagram-mark--lightbox" aria-hidden="true">
        <svg viewBox="0 0 48 48" width="16" height="16">
          <rect x="5" y="5" width="38" height="38" rx="2" fill="#1a1a1a"/>
          <g fill="none" stroke="#f7f5f0" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="10" cy="10" r="1.8" stroke-width="1.2"/>
            <circle cx="38" cy="10" r="1.8" stroke-width="1.2"/>
            <circle cx="10" cy="38" r="1.8" stroke-width="1.2"/>
            <circle cx="38" cy="38" r="1.8" stroke-width="1.2"/>
            <path d="M 13 24 C 16 24, 17 32, 20 32 C 23 32, 23 16, 26 16 C 29 16, 30 24, 35 24" stroke-width="2"/>
          </g>
          <circle cx="26" cy="16" r="2" fill="#d9571f"/>
        </svg>
        <span>Voltpages</span>
      </div>`;

    document.querySelectorAll('.diagram-expand-btn').forEach((btn) => {
      btn.addEventListener('click', (e) => {
        e.preventDefault();
        const shell = btn.closest('.diagram-shell');
        const svg = shell && shell.querySelector('.diagram-svg');
        if (!svg) return;
        body.innerHTML = svg.innerHTML + MARK_HTML;
        applyDiagramSizing(body);
        if (typeof dialog.showModal === 'function') {
          dialog.showModal();
        } else {
          const blob = new Blob([svg.innerHTML], { type: 'image/svg+xml' });
          window.open(URL.createObjectURL(blob));
        }
      });
    });

    dialog.addEventListener('click', (e) => {
      const rect = dialog.getBoundingClientRect();
      const inDialog = e.clientY >= rect.top && e.clientY <= rect.bottom &&
                       e.clientX >= rect.left && e.clientX <= rect.right;
      if (!inDialog) dialog.close();
    });

    // Open all <details> for print (CSS alone can't override the UA's
    // collapsed-content behavior) and restore their state after.
    const previousOpenState = new WeakMap();
    function openAllForPrint() {
      document.querySelectorAll('details').forEach((d) => {
        previousOpenState.set(d, d.open);
        d.open = true;
      });
    }
    function restoreAfterPrint() {
      document.querySelectorAll('details').forEach((d) => {
        if (previousOpenState.has(d)) d.open = previousOpenState.get(d);
      });
    }
    window.addEventListener('beforeprint', openAllForPrint);
    window.addEventListener('afterprint', restoreAfterPrint);
    // Safari / older browsers only expose matchMedia('print') transitions.
    if (window.matchMedia) {
      const mql = window.matchMedia('print');
      const onChange = (e) => (e.matches ? openAllForPrint() : restoreAfterPrint());
      if (mql.addEventListener) mql.addEventListener('change', onChange);
      else if (mql.addListener) mql.addListener(onChange);
    }

    applyDiagramSizing(document);
  })();
</script>
