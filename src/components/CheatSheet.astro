---
import type { Module } from '../types/module';
import ModuleHeader from './ModuleHeader.astro';
import ControlsTable from './ControlsTable.astro';
import IOPanel from './IOPanel.astro';
import BehaviorsPanel from './BehaviorsPanel.astro';
import PatchIdeas from './PatchIdeas.astro';

interface Props {
  module: Module;
  expanders?: Module[];
}

const { module, expanders = [] } = Astro.props;
const basePath = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<div class="max-w-[1100px] mx-auto bg-bg min-h-screen">
  <nav class="px-4 md:px-7 pt-4 pb-0 flex justify-between items-center">
    <a href={`${basePath}/`} class="flex items-center gap-2 text-xs font-mono text-subtle hover:text-fg no-underline tracking-[3px] uppercase" aria-label="Back to all modules">
      <svg viewBox="0 0 48 48" width="20" height="20" aria-hidden="true" class="flex-shrink-0">
        <rect x="5" y="5" width="38" height="38" rx="2" fill="#1a1a1a"/>
        <g fill="none" stroke="#f7f5f0" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="10" cy="10" r="1.8" stroke-width="1.2"/>
          <circle cx="38" cy="10" r="1.8" stroke-width="1.2"/>
          <circle cx="10" cy="38" r="1.8" stroke-width="1.2"/>
          <circle cx="38" cy="38" r="1.8" stroke-width="1.2"/>
          <path d="M 13 24 C 16 24, 17 32, 20 32 C 23 32, 23 16, 26 16 C 29 16, 30 24, 35 24" stroke-width="2"/>
        </g>
        <circle cx="26" cy="16" r="2" fill="#d9571f"/>
      </svg>
      <span>Voltpages</span>
    </a>
  </nav>
  <ModuleHeader
    name={module.name}
    manufacturer={module.manufacturer}
    hp={module.hp}
    tags={module.tags}
    verified={module._meta.verified}
    firmwareVersion={module._meta.firmwareVersion}
  />
  <p class="px-4 md:px-7 pt-3 pb-0 text-sm text-muted leading-relaxed">{module.description}</p>

  <!-- Section nav -->
  <nav class="px-4 md:px-7 pt-5 pb-3 flex gap-1.5 md:gap-2 sticky top-0 bg-bg z-10 border-b border-border overflow-x-auto" aria-label="Module sections">
    <a href="#patches" class="text-[11px] md:text-xs font-mono text-subtle hover:text-fg no-underline tracking-wide uppercase px-2.5 md:px-3 py-1.5 border border-border hover:border-border-strong whitespace-nowrap shrink-0">Patches</a>
    <a href="#behaviors" class="text-[11px] md:text-xs font-mono text-subtle hover:text-fg no-underline tracking-wide uppercase px-2.5 md:px-3 py-1.5 border border-border hover:border-border-strong whitespace-nowrap shrink-0">Behaviors</a>
    <a href="#controls" class="text-[11px] md:text-xs font-mono text-subtle hover:text-fg no-underline tracking-wide uppercase px-2.5 md:px-3 py-1.5 border border-border hover:border-border-strong whitespace-nowrap shrink-0">Controls</a>
    <a href="#io" class="text-[11px] md:text-xs font-mono text-subtle hover:text-fg no-underline tracking-wide uppercase px-2.5 md:px-3 py-1.5 border border-border hover:border-border-strong whitespace-nowrap shrink-0">I/O</a>
    {expanders.length > 0 && (
      <a href="#expanders" class="text-[11px] md:text-xs font-mono text-subtle hover:text-fg no-underline tracking-wide uppercase px-2.5 md:px-3 py-1.5 border border-border hover:border-border-strong whitespace-nowrap shrink-0">Expanders</a>
    )}
  </nav>

  <!-- Patch Ideas -->
  <section id="patches" data-pagefind-filter="section:patches" class="px-4 md:px-7 py-5 md:py-6 border-b border-border scroll-mt-12">
    <PatchIdeas patchIdeas={module.patchIdeas} />
  </section>

  <!-- Behaviors -->
  <section id="behaviors" data-pagefind-filter="section:behaviors" class="px-4 md:px-7 py-5 md:py-6 border-b border-border scroll-mt-12">
    <BehaviorsPanel behaviors={module.behaviors} />
  </section>

  <!-- Controls -->
  <section id="controls" data-pagefind-filter="section:controls" class="px-4 md:px-7 py-5 md:py-6 border-b border-border scroll-mt-12">
    <ControlsTable controls={module.controls} />
  </section>

  <!-- I/O -->
  <section id="io" data-pagefind-filter="section:io" class="px-4 md:px-7 py-5 md:py-6 scroll-mt-12 border-b border-border">
    <IOPanel inputs={module.inputs} outputs={module.outputs} />
  </section>

  {expanders.length > 0 && (
    <section id="expanders" class="px-4 md:px-7 py-5 md:py-6 scroll-mt-12">
      <h2 class="text-xs uppercase tracking-[3px] text-subtle font-mono mb-4">Expanders</h2>
      <div class="flex flex-col gap-6">
        {expanders.map((exp) => (
          <details class="border border-border">
            <summary class="px-3 py-2 cursor-pointer bg-surface text-sm font-semibold text-fg flex justify-between items-baseline">
              <span>{exp.name}</span>
              <span class="text-[11px] font-mono text-subtle tracking-wide uppercase">{exp.hp}HP</span>
            </summary>
            <div class="px-3 py-3 border-t border-border">
              <p class="text-sm text-muted leading-relaxed mb-4">{exp.description}</p>
              {exp.behaviors.length > 0 && (
                <div class="mb-4">
                  <BehaviorsPanel behaviors={exp.behaviors} />
                </div>
              )}
              {exp.patchIdeas.length > 0 && (
                <div class="mb-4">
                  <PatchIdeas patchIdeas={exp.patchIdeas} />
                </div>
              )}
              {(exp.inputs.length > 0 || exp.outputs.length > 0) && (
                <div class="mb-4">
                  <IOPanel inputs={exp.inputs} outputs={exp.outputs} />
                </div>
              )}
              {exp.controls.length > 0 && (
                <ControlsTable controls={exp.controls} />
              )}
            </div>
          </details>
        ))}
      </div>
    </section>
  )}

</div>
