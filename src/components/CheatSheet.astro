---
import type { Module } from '../types/module';
import ModuleHeader from './ModuleHeader.astro';
import ControlsTable from './ControlsTable.astro';
import IOPanel from './IOPanel.astro';
import BehaviorsPanel from './BehaviorsPanel.astro';
import PatchIdeas from './PatchIdeas.astro';

interface Props {
  module: Module;
  expanders?: Module[];
}

const { module, expanders = [] } = Astro.props;
const basePath = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<div class="max-w-[1100px] mx-auto bg-bg min-h-screen">
  <nav class="px-4 md:px-7 pt-4 pb-0 flex justify-between items-center">
    <a href={`${basePath}/`} class="flex items-center gap-2 text-xs font-mono text-subtle hover:text-fg no-underline tracking-[3px] uppercase" aria-label="Back to all modules">
      <svg viewBox="0 0 48 48" width="20" height="20" aria-hidden="true" class="flex-shrink-0">
        <rect x="5" y="5" width="38" height="38" rx="2" fill="#1a1a1a"/>
        <g fill="none" stroke="#f7f5f0" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="10" cy="10" r="1.8" stroke-width="1.2"/>
          <circle cx="38" cy="10" r="1.8" stroke-width="1.2"/>
          <circle cx="10" cy="38" r="1.8" stroke-width="1.2"/>
          <circle cx="38" cy="38" r="1.8" stroke-width="1.2"/>
          <path d="M 13 24 C 16 24, 17 32, 20 32 C 23 32, 23 16, 26 16 C 29 16, 30 24, 35 24" stroke-width="2"/>
        </g>
        <circle cx="26" cy="16" r="2" fill="#d9571f"/>
      </svg>
      <span>Voltpages</span>
    </a>
  </nav>
  <ModuleHeader
    name={module.name}
    manufacturer={module.manufacturer}
    hp={module.hp}
    tags={module.tags}
    verified={module._meta.verified}
    firmwareVersion={module._meta.firmwareVersion}
  />
  <p class="px-4 md:px-7 pt-3 pb-0 text-sm text-muted leading-relaxed">{module.description}</p>

  <!-- Section nav -->
  <div class="sticky top-0 bg-bg z-10 border-b border-border">
    <nav class="section-nav px-4 md:px-7 pt-5 pb-3 flex gap-1.5 md:gap-2 overflow-x-auto items-center" aria-label="Module sections">
      <a href="#patches" data-section-link="patches" class="section-link text-[11px] md:text-xs font-mono text-subtle hover:text-fg no-underline tracking-wide uppercase px-3 min-h-[44px] md:min-h-0 md:py-1.5 border border-border hover:border-border-strong whitespace-nowrap shrink-0 inline-flex items-center">
        <span class="section-link-label">Patches</span>
        <span class="section-link-count hidden ml-1 text-faint" aria-hidden="true"></span>
      </a>
      <a href="#behaviors" data-section-link="behaviors" class="section-link text-[11px] md:text-xs font-mono text-subtle hover:text-fg no-underline tracking-wide uppercase px-3 min-h-[44px] md:min-h-0 md:py-1.5 border border-border hover:border-border-strong whitespace-nowrap shrink-0 inline-flex items-center">Behaviors</a>
      <a href="#controls" data-section-link="controls" class="section-link text-[11px] md:text-xs font-mono text-subtle hover:text-fg no-underline tracking-wide uppercase px-3 min-h-[44px] md:min-h-0 md:py-1.5 border border-border hover:border-border-strong whitespace-nowrap shrink-0 inline-flex items-center">Controls</a>
      <a href="#io" data-section-link="io" class="section-link text-[11px] md:text-xs font-mono text-subtle hover:text-fg no-underline tracking-wide uppercase px-3 min-h-[44px] md:min-h-0 md:py-1.5 border border-border hover:border-border-strong whitespace-nowrap shrink-0 inline-flex items-center">I/O</a>
      {expanders.length > 0 && (
        <a href="#expanders" data-section-link="expanders" class="section-link text-[11px] md:text-xs font-mono text-subtle hover:text-fg no-underline tracking-wide uppercase px-3 min-h-[44px] md:min-h-0 md:py-1.5 border border-border hover:border-border-strong whitespace-nowrap shrink-0 inline-flex items-center">Expanders</a>
      )}
      <button
        type="button"
        id="print-btn"
        class="text-[11px] md:text-xs font-mono text-subtle hover:text-fg no-underline tracking-wide uppercase px-3 min-h-[44px] md:min-h-0 md:py-1.5 border border-border hover:border-border-strong whitespace-nowrap shrink-0 inline-flex items-center gap-1 ml-auto cursor-pointer bg-transparent"
        aria-label="Print or save as PDF"
        title="Print / PDF (⌘P)"
      >
        <span aria-hidden="true">⎙</span>
        <span>Print / PDF</span>
      </button>
    </nav>
    <div class="section-nav-progress" aria-hidden="true">
      <div id="section-nav-progress-fill" class="section-nav-progress-fill"></div>
    </div>
  </div>

  <!-- Patch Ideas -->
  <section id="patches" data-pagefind-filter="section:patches" class="px-4 md:px-7 py-5 md:py-6 border-b border-border scroll-mt-12">
    <PatchIdeas patchIdeas={module.patchIdeas} />
  </section>

  <!-- Behaviors -->
  <section id="behaviors" data-pagefind-filter="section:behaviors" class="px-4 md:px-7 py-5 md:py-6 border-b border-border scroll-mt-12">
    <BehaviorsPanel behaviors={module.behaviors} />
  </section>

  <!-- Controls -->
  <section id="controls" data-pagefind-filter="section:controls" class="px-4 md:px-7 py-5 md:py-6 border-b border-border scroll-mt-12">
    <ControlsTable controls={module.controls} />
  </section>

  <!-- I/O -->
  <section id="io" data-pagefind-filter="section:io" class="px-4 md:px-7 py-5 md:py-6 scroll-mt-12 border-b border-border">
    <IOPanel inputs={module.inputs} outputs={module.outputs} />
  </section>

  {expanders.length > 0 && (
    <section id="expanders" data-pagefind-filter="section:expanders" class="px-4 md:px-7 py-5 md:py-6 scroll-mt-12">
      <h2 class="text-xs uppercase tracking-[3px] text-subtle font-mono mb-4">Expanders</h2>
      <div class="flex flex-col gap-6">
        {expanders.map((exp) => (
          <details class="border border-border">
            <summary class="px-3 py-2 cursor-pointer bg-surface text-sm font-semibold text-fg flex justify-between items-baseline">
              <span>{exp.name}</span>
              <span class="text-[11px] font-mono text-subtle tracking-wide uppercase">{exp.hp}HP</span>
            </summary>
            <div class="px-3 py-3 border-t border-border">
              <p class="text-sm text-muted leading-relaxed mb-4">{exp.description}</p>
              {exp.behaviors.length > 0 && (
                <div class="mb-4">
                  <BehaviorsPanel behaviors={exp.behaviors} />
                </div>
              )}
              {exp.patchIdeas.length > 0 && (
                <div class="mb-4">
                  <PatchIdeas patchIdeas={exp.patchIdeas} />
                </div>
              )}
              {(exp.inputs.length > 0 || exp.outputs.length > 0) && (
                <div class="mb-4">
                  <IOPanel inputs={exp.inputs} outputs={exp.outputs} />
                </div>
              )}
              {exp.controls.length > 0 && (
                <ControlsTable controls={exp.controls} />
              )}
            </div>
          </details>
        ))}
      </div>
    </section>
  )}

</div>

<script is:inline define:vars={{ patchCount: module.patchIdeas.length }}>
  (function () {
    const links = Array.from(document.querySelectorAll('[data-section-link]'));
    if (links.length === 0) return;

    // Active-section tracking. rootMargin biases the trigger to roughly the
    // upper third of the viewport so the active chip changes shortly after a
    // section's heading crosses the top, not when its last pixel leaves.
    const sections = links
      .map((link) => {
        const id = link.getAttribute('data-section-link');
        const el = id ? document.getElementById(id) : null;
        return el ? { id, el, link } : null;
      })
      .filter(Boolean);

    function setActive(id) {
      for (const s of sections) {
        const active = s.id === id;
        if (active) s.link.setAttribute('aria-current', 'location');
        else s.link.removeAttribute('aria-current');
      }
    }

    const visible = new Set();
    if (typeof IntersectionObserver === 'function') {
      const io = new IntersectionObserver(
        (entries) => {
          for (const entry of entries) {
            const id = entry.target.id;
            if (entry.isIntersecting) visible.add(id);
            else visible.delete(id);
          }
          // Pick the first section in document order that is currently visible —
          // this matches the "what am I looking at" intent better than picking
          // the most-intersected section, which flickers on short sections.
          const first = sections.find((s) => visible.has(s.id));
          if (first) setActive(first.id);
        },
        { rootMargin: '-20% 0px -70% 0px', threshold: 0 },
      );
      for (const s of sections) io.observe(s.el);
    }

    // Patches chip count: "Patches · N / total" while the user is scrolling
    // within the patches section, plain "Patches" otherwise.
    const patchesLink = links.find((l) => l.getAttribute('data-section-link') === 'patches');
    const patchesSection = document.getElementById('patches');
    const patchesCountEl = patchesLink && patchesLink.querySelector('.section-link-count');

    function updatePatchCount() {
      if (!patchesLink || !patchesSection || !patchesCountEl) return;
      const rect = patchesSection.getBoundingClientRect();
      const inSection = rect.top < window.innerHeight * 0.5 && rect.bottom > 0;
      if (!inSection) {
        patchesCountEl.classList.add('hidden');
        patchesCountEl.textContent = '';
        return;
      }
      const cards = patchesSection.querySelectorAll('[data-patch-card]');
      const total = cards.length || patchCount;
      let seen = 0;
      cards.forEach((c) => {
        if (c.getBoundingClientRect().top < window.innerHeight * 0.5) seen++;
      });
      const display = Math.min(Math.max(seen, 1), total);
      patchesCountEl.textContent = `· ${display} / ${total}`;
      patchesCountEl.classList.remove('hidden');
    }

    // Scroll progress rule under the sticky nav.
    const fill = document.getElementById('section-nav-progress-fill');
    let rafPending = false;
    function onScroll() {
      if (rafPending) return;
      rafPending = true;
      requestAnimationFrame(() => {
        rafPending = false;
        if (fill) {
          const docHeight = document.documentElement.scrollHeight - window.innerHeight;
          const pct = docHeight > 0 ? Math.min(100, Math.max(0, (window.scrollY / docHeight) * 100)) : 0;
          fill.style.width = pct + '%';
        }
        updatePatchCount();
      });
    }
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();

    const printBtn = document.getElementById('print-btn');
    if (printBtn) {
      printBtn.addEventListener('click', () => window.print());
    }
  })();
</script>
