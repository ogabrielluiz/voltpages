---
import type { IO, SignalType } from '../types/module';

interface Props {
  inputs: IO[];
  outputs: IO[];
}

const { inputs, outputs } = Astro.props;

// Infer a display-only signal type from voltage + description when the sheet
// doesn't specify one. The authored `signalType` field always wins.
function inferSignalType(io: IO): SignalType | null {
  if (io.signalType) return io.signalType;
  const hay = `${io.name} ${io.description} ${io.voltage ?? ''} ${io.normalizedTo ?? ''}`.toLowerCase();
  if (/\b(gate|trig(ger)?|pulse)\b/.test(hay)) return 'gate';
  if (/\b(clock|clk|bpm|tempo)\b/.test(hay)) return 'clk';
  if (/\b(envelope|env)\b/.test(hay)) return 'env';
  if (/\b(v\/oct|v-?oct|volt[- ]?per[- ]?octave|cv|modulation|control voltage)\b/.test(hay)) return 'cv';
  if (/\b(audio|vca|vcf|signal input|signal output|vco|oscillat|line[- ]level)\b/.test(hay)) return 'audio';
  return null;
}

const SIGNAL_LABEL: Record<SignalType, string> = {
  cv: 'CV',
  gate: 'GATE',
  audio: 'AUDIO',
  env: 'ENV',
  clk: 'CLK',
};
---

<div class="mt-6">
  <h2 class="text-xs uppercase tracking-[3px] text-subtle font-mono mb-4">I/O</h2>
  <div class="grid grid-cols-1 md:grid-cols-2 gap-x-10 md:gap-x-12 gap-y-8">
    {inputs.length > 0 && (
      <section aria-label="Inputs">
        <h3 class="io-heading io-heading--in py-1.5 text-[10px] font-mono uppercase tracking-[2px] border-b border-border flex items-center gap-1.5">
          <span aria-hidden="true">▸</span>
          <span>IN</span>
          <span class="text-faint font-normal">· {inputs.length}</span>
        </h3>
        <ul class="text-sm list-none pl-0">
          {inputs.map((input) => {
            const signal = inferSignalType(input);
            return (
              <li class="io-row io-row--in py-2 border-b border-border last:border-b-0">
                <div class="flex items-baseline gap-3 flex-wrap">
                  <span class="text-[15px] font-semibold text-fg">{input.name}</span>
                  {input.voltage && (
                    <span class="text-xs font-mono text-subtle">{input.voltage}</span>
                  )}
                  {signal && (
                    <span class="io-chip">{SIGNAL_LABEL[signal]}</span>
                  )}
                </div>
                <div class="text-muted mt-0.5">
                  {input.description}
                  {input.normalizedTo && (
                    <div class="mt-1">
                      <span class="io-norm-kicker">NORM →</span>
                      <span class="text-xs text-subtle ml-1.5">{input.normalizedTo}</span>
                    </div>
                  )}
                </div>
              </li>
            );
          })}
        </ul>
      </section>
    )}
    {outputs.length > 0 && (
      <section aria-label="Outputs">
        <h3 class="io-heading io-heading--out py-1.5 text-[10px] font-mono uppercase tracking-[2px] border-b border-border flex items-center gap-1.5">
          <span aria-hidden="true">◂</span>
          <span>OUT</span>
          <span class="text-faint font-normal">· {outputs.length}</span>
        </h3>
        <ul class="text-sm list-none pl-0">
          {outputs.map((output) => {
            const signal = inferSignalType(output);
            return (
              <li class="io-row io-row--out py-2 border-b border-border last:border-b-0">
                <div class="flex items-baseline gap-3 flex-wrap">
                  <span class="text-[15px] font-semibold text-fg">{output.name}</span>
                  {output.voltage && (
                    <span class="text-xs font-mono text-subtle">{output.voltage}</span>
                  )}
                  {signal && (
                    <span class="io-chip">{SIGNAL_LABEL[signal]}</span>
                  )}
                </div>
                <div class="text-muted mt-0.5">
                  {output.description}
                  {output.normalizedTo && (
                    <div class="mt-1">
                      <span class="io-norm-kicker">NORM →</span>
                      <span class="text-xs text-subtle ml-1.5">{output.normalizedTo}</span>
                    </div>
                  )}
                </div>
              </li>
            );
          })}
        </ul>
      </section>
    )}
  </div>
</div>
