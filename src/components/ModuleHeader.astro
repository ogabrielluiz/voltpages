---
interface Props {
  name: string;
  manufacturer: string;
  hp: number;
  tags: string[];
  verified: boolean;
  firmwareVersion?: string;
}

const { name, manufacturer, hp, tags, verified, firmwareVersion } = Astro.props;
---

<header class="px-4 md:px-7 py-4 md:py-5 border-b-2 border-border-strong">
  <div class="flex flex-col gap-2 md:flex-row md:justify-between md:items-baseline">
    <div>
      <div class="flex items-baseline gap-3 flex-wrap">
        <h1 class="text-2xl md:text-[28px] font-bold text-fg tracking-tight">{name}</h1>
        <span class="text-[13px] text-subtle">{manufacturer}</span>
        <span class="text-[13px] text-subtle font-mono">{hp}HP</span>
      </div>
      <div class="flex items-center gap-3 mt-1">
        {firmwareVersion && (
          <span class="text-xs font-mono text-subtle">fw {firmwareVersion}</span>
        )}
        {!verified && (
          <span class="text-[11px] font-mono text-subtle tracking-wide uppercase">AI-generated</span>
        )}
      </div>
    </div>
    <div class="flex gap-1.5 flex-wrap">
      {tags.map((tag) => (
        <span class="text-[11px] md:text-xs font-mono text-muted tracking-[1px] uppercase px-2 py-0.5 border border-tag-border">
          {tag}
        </span>
      ))}
    </div>
  </div>
</header>
