---
interface Props {
  name: string;
  manufacturer: string;
  hp: number;
  tags: string[];
  verified: boolean;
  firmwareVersion?: string;
}

const { name, manufacturer, hp, tags, verified, firmwareVersion } = Astro.props;
---

<header class="px-7 py-5 border-b-2 border-border-strong">
  <div class="flex justify-between items-baseline flex-wrap gap-2">
    <div class="flex items-baseline gap-3.5 flex-wrap">
      <h1 class="text-[28px] font-bold text-fg tracking-tight">{name}</h1>
      <span class="text-[13px] text-subtle">{manufacturer}</span>
      <span class="text-[13px] text-border">·</span>
      <span class="text-[13px] text-subtle font-mono">{hp}HP</span>
      {firmwareVersion && (
        <span class="text-[10px] font-mono text-faint">fw {firmwareVersion}</span>
      )}
      {!verified && (
        <span class="text-[9px] font-mono text-faint tracking-wide uppercase">AI-generated</span>
      )}
    </div>
    <div class="flex gap-2 flex-wrap">
      {tags.map((tag) => (
        <span class="text-[10px] font-mono text-muted tracking-[1px] uppercase px-2 py-0.5 border border-tag-border">
          {tag}
        </span>
      ))}
    </div>
  </div>
</header>
