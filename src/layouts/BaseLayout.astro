---
interface Props {
  title: string;
  description?: string;
  ogTitle?: string;
  ogDescription?: string;
  ogImage?: string;
}

const { title, description = "Cheat sheets for your eurorack modular system", ogTitle, ogDescription, ogImage } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const displayTitle = `${title} — Voltpages`;
const basePath = import.meta.env.BASE_URL.replace(/\/$/, '');
const goatcounterCode = import.meta.env.PUBLIC_GOATCOUNTER_CODE || 'ogabrielluiz';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href={`${basePath}/favicon.svg`} />
    <link rel="canonical" href={canonicalURL.href} />

    <meta name="theme-color" content="#f7f5f0" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={ogTitle || displayTitle} />
    <meta property="og:description" content={ogDescription || description} />
    <meta property="og:url" content={canonicalURL.href} />
    <meta property="og:site_name" content="Voltpages" />
    {ogImage && <meta property="og:image" content={new URL(`${basePath}${ogImage}`, Astro.site).href} />}
    {ogImage && <meta property="og:image:width" content="1200" />}
    {ogImage && <meta property="og:image:height" content="630" />}

    <!-- Twitter Card -->
    <meta name="twitter:card" content={ogImage ? "summary_large_image" : "summary"} />
    <meta name="twitter:title" content={ogTitle || displayTitle} />
    <meta name="twitter:description" content={ogDescription || description} />
    {ogImage && <meta name="twitter:image" content={new URL(`${basePath}${ogImage}`, Astro.site).href} />}

    <title>{displayTitle}</title>
  </head>
  <body class="bg-bg text-fg font-sans antialiased">
    <a href="#main-content" class="skip-link">Skip to content</a>
    <main id="main-content">
      <slot />
    </main>

    <!-- GoatCounter analytics — privacy-friendly, no cookies, free for open source -->
    {goatcounterCode && (
      <script
        data-goatcounter={`https://${goatcounterCode}.goatcounter.com/count`}
        async
        src="//gc.zgo.at/count.js"
      ></script>
    )}

    <!-- Custom event tracking -->
    <script is:inline>
      function trackEvent(name, title) {
        if (window.goatcounter && window.goatcounter.count) {
          window.goatcounter.count({ path: name, title: title, event: true });
        }
      }

      document.addEventListener('DOMContentLoaded', () => {
        // Track section nav clicks (which sections people jump to)
        document.querySelectorAll('nav[aria-label="Module sections"] a').forEach(link => {
          link.addEventListener('click', () => {
            const section = link.getAttribute('href').replace('#', '');
            const module = document.querySelector('h1')?.textContent || '';
            trackEvent(`section-${section}`, `${module} → ${section}`);
          });
        });

        // Track print button clicks
        document.querySelectorAll('button[onclick="window.print()"]').forEach(btn => {
          btn.addEventListener('click', () => {
            const module = document.querySelector('h1')?.textContent || '';
            trackEvent(`print-${module}`, `Print: ${module}`);
          });
        });

        // Track outbound link clicks (contribute, etc.)
        document.querySelectorAll('a[href^="http"]').forEach(link => {
          link.addEventListener('click', () => {
            trackEvent(`outbound-${link.hostname}`, link.textContent.trim());
          });
        });

        // Track search usage
        const searchInput = document.querySelector('.pagefind-ui__search-input');
        if (searchInput) {
          let searchTimeout;
          searchInput.addEventListener('input', () => {
            clearTimeout(searchTimeout);
            searchTimeout = setTimeout(() => {
              const query = searchInput.value.trim();
              if (query.length >= 2) {
                trackEvent(`search`, `Search: ${query}`);
              }
            }, 1000);
          });
        }

        // Track module clicks from home page
        document.querySelectorAll('a[href*="/modules/"]').forEach(link => {
          link.addEventListener('click', () => {
            const module = link.textContent.trim();
            trackEvent(`open-${module}`, `Open: ${module}`);
          });
        });
      });
    </script>
  </body>
</html>
