{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "title": "Eurorack Module Cheat Sheet",
  "type": "object",
  "required": ["_meta", "slug", "name", "manufacturer", "hp", "tags", "description", "controls", "inputs", "outputs", "behaviors", "patchIdeas"],
  "properties": {
    "$schema": { "type": "string" },
    "_meta": {
      "type": "object",
      "required": ["schemaVersion", "verified"],
      "properties": {
        "schemaVersion": { "type": "number", "const": 1 },
        "generatedAt": { "type": "string" },
        "verified": { "type": "boolean" },
        "firmwareVersion": { "type": "string" },
        "sources": {
          "type": "array",
          "description": "URLs consulted while building this sheet (manual, ModularGrid, Modwiggler threads, Reddit, etc.). Used to audit and re-verify.",
          "items": { "type": "string", "format": "uri" }
        },
        "expanderOf": {
          "type": "string",
          "description": "Slug of the parent module this one expands. When set, this sheet is rendered inline on the parent's page and hidden from the top-level module listing."
        },
        "hidden": {
          "type": "boolean",
          "description": "When true, keep the sheet in the repo for research/reference purposes but do not generate a public page or surface it in the UI."
        }
      }
    },
    "slug": { "type": "string", "pattern": "^[a-z0-9-]+--[a-z0-9-]+$" },
    "name": { "type": "string", "minLength": 1 },
    "manufacturer": { "type": "string", "minLength": 1 },
    "hp": { "type": "integer", "minimum": 1 },
    "tags": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": [
          "OSCILLATOR", "VCO", "VCA", "VCF", "FILTER", "ENVELOPE", "LFO",
          "FUNCTION", "SEQUENCER", "CLOCK", "UTILITY", "MIXER", "REVERB",
          "DELAY", "EFFECTS", "DISTORTION", "GRANULAR", "SAMPLER", "WAVESHAPER",
          "QUANTIZER", "NOISE", "SLEW", "RANDOM", "LOGIC", "SWITCH",
          "ATTENUATOR", "ATTENUVERTER", "TRIGGER", "GATE", "DRUM",
          "COMPRESSOR", "EQ", "PHASER", "CHORUS", "GLITCH", "BUFFER",
          "RESONATOR", "WAVEFOLDER", "MIDI", "I/O", "MULT"
        ]
      }
    },
    "description": { "type": "string", "minLength": 10, "maxLength": 300 },
    "controls": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "scope", "description", "detail"],
        "properties": {
          "name": { "type": "string" },
          "scope": { "type": "string" },
          "description": { "type": "string", "maxLength": 120 },
          "detail": { "type": "string" }
        }
      }
    },
    "inputs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "description"],
        "properties": {
          "name": { "type": "string" },
          "description": { "type": "string" },
          "voltage": { "type": "string" },
          "normalizedTo": { "type": "string" }
        }
      }
    },
    "outputs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "description"],
        "properties": {
          "name": { "type": "string" },
          "description": { "type": "string" },
          "voltage": { "type": "string" },
          "normalizedTo": { "type": "string" }
        }
      }
    },
    "behaviors": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "trigger", "description"],
        "properties": {
          "name": { "type": "string" },
          "trigger": { "type": "string" },
          "description": { "type": "string" }
        }
      }
    },
    "patchIdeas": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "patch"],
        "properties": {
          "name": { "type": "string" },
          "patch": {
            "type": "string",
            "description": "Concise one-liner summarizing what the patch does and why. Served as-is when no walkthrough is authored."
          },
          "diagram": {
            "type": "string",
            "description": "Patchflow notation for rendering a signal flow diagram"
          },
          "steps": {
            "type": "array",
            "description": "Ordered beginner-friendly instructions. Each step is one settings tweak or one patch cable. Consumed by the UI as a numbered list.",
            "items": { "type": "string" }
          },
          "signalOut": {
            "type": "string",
            "description": "Where the useful signal comes out and what it is — e.g. 'CH 1 OUT — envelope CV, patch into a VCA'. Shown prominently so beginners know what to do with the result."
          },
          "hear": {
            "type": "string",
            "description": "What the reader should expect to hear or see once patched — concrete behavior, not metaphor."
          }
        }
      }
    }
  }
}
